      <aliases enabled='yes' />
      <column caption='Default Rate' datatype='real' name='[Calculation_0528371051298816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_default])*100.0/ COUNT([loan_id])' />
      </column>
      <column caption='Default Exposure %' datatype='real' name='[Calculation_0528371051692033]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [is_default] = 1 then [loan_amount] END&#13;&#10;)/ SUM([loan_amount])' />
      </column>
      <column caption='Months' datatype='datetime' name='[Calculation_0528371058102274]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [sanctioned_date])' />
      </column>
      <column caption='Loan Tenure ' datatype='string' name='[Calculation_0528371097337859]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [loan_tenure_months] &gt;= 18 then &quot;Long Term&quot;&#13;&#10;ELSEIF  [loan_tenure_months] &gt;= 12 then &quot;Mid Term&quot;&#13;&#10;ELSE &apos;Short Term&apos;&#13;&#10;END' />
      </column>
      <column caption='Credit Score Bucket ' datatype='string' name='[Calculation_0528371101552644]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [credit_score] &gt;= 800 then &quot;Excellent (800+)&quot;&#13;&#10;ELSEIF  [credit_score] &gt;= 740 then &quot;Very Good (740-799)&quot;&#13;&#10;ELSEIF [credit_score] &gt;= 670 then &quot;Good (670-739)&quot;&#13;&#10;ELSEIF [credit_score] &gt;= 580 then &quot;Fair (580-669)&quot;&#13;&#10;else &quot;Poor (&lt;580)&quot;&#13;&#10;end' />
      </column>
      <column caption='Income Group ' datatype='string' name='[Calculation_0528371111395333]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [monthly_income] &gt;= 100000 then &apos;High Earners&apos;&#13;&#10;ELSEIF [monthly_income] &gt;= 50000 then &apos;Mid Earners&apos;&#13;&#10;ELSE &apos;Low Earners&apos;&#13;&#10;END' />
      </column>
      <column caption='Avg Loan Amt' datatype='real' name='[Calculation_0680654105817089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([loan_amount])' />
      </column>
      <column caption='Defaulted Amount' datatype='integer' name='[Calculation_0680654107275266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(IF [is_default] = 1 THEN [loan_amount] END)' />
      </column>
      <column caption='Tenure Bucket' datatype='real' name='[Calculation_0680654111330308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0528371097337859] &gt;= &apos;11&apos; THEN &apos;Short Term Loan&apos;&#13;&#10;ELSEIF [Calculation_0528371097337859] &gt;= 17 THEN &apos;Mid Tern Loan&apos;&#13;&#10;ELSE &apos;Long Term Loan&apos;&#13;&#10;END' />
      </column>
      <column caption='Loans with Mssed Payments' datatype='integer' name='[Calculation_0689725034840064]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [is_missed_payment] &gt; 0&#13;&#10;    THEN [loan_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Avg Late Payment Ratio' datatype='real' name='[Calculation_0689725035954177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([late_payment_ratio])' />
      </column>
      <column caption='Avg DTI Ratio' datatype='real' name='[Calculation_0689725036920834]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([debt_to_income_ratio])' />
      </column>
      <column caption='Missed Payments Bucket' datatype='string' name='[Calculation_0689725038436355]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [total_missed_payments] = 0 THEN &quot;0 Missed&quot;&#13;&#10;ELSEIF [total_missed_payments] &lt;= 3 THEN &apos;1-3 Missed Payments&apos;&#13;&#10;ELSEIF [total_missed_payments] &lt;= 5 THEN &quot;4–5 Missed Payments&quot;&#13;&#10;ELSE &quot;6+ Missed Payments&quot;&#13;&#10;END' />
      </column>
      <column caption='Late Payment (%)' datatype='string' name='[Calculation_0689725046153220]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [late_payment_ratio] &lt;= 0.10 THEN &quot;0–10%&quot;ELSEIF [late_payment_ratio] &lt;= 0.20 THEN &quot;10–20%&quot;ELSEIF [late_payment_ratio] &lt;= 0.30 THEN &quot;20–30%&quot;ELSEIF [late_payment_ratio] &lt;= 0.50 THEN &quot;30–50%&quot;ELSE &quot;50%+&quot;END' />
      </column>
      <column caption='DBT Ratio' datatype='string' name='[Calculation_0689725051990021]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [debt_to_income_ratio] &lt;= 0.20 THEN &quot;0–20%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.30 THEN &quot;20–30%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.40 THEN &quot;30–40%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.50 THEN &quot;40–50%&quot;ELSE &quot;50%+&quot;END' />
      </column>

    <worksheet name='Default Rate By Debt to Income Ratio'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontname='Tableau Semibold' fontsize='12'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_loans_data+' name='federated.0hufx7l0d94me718yhw6l1wi1kgp' />
          </datasources>
          <datasource-dependencies datasource='federated.0hufx7l0d94me718yhw6l1wi1kgp'>
            <column caption='Default Rate' datatype='real' name='[Calculation_0528371051298816]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([is_default])*100.0/ COUNT([loan_id])' />
            </column>
            <column caption='DBT Ratio' datatype='string' name='[Calculation_0689725051990021]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [debt_to_income_ratio] &lt;= 0.20 THEN &quot;0–20%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.30 THEN &quot;20–30%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.40 THEN &quot;30–40%&quot;ELSEIF [debt_to_income_ratio] &lt;= 0.50 THEN &quot;40–50%&quot;ELSE &quot;50%+&quot;END' />
            </column>
            <column caption='Debt To Income Ratio' datatype='real' name='[debt_to_income_ratio]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Is Default' datatype='integer' name='[is_default]' role='dimension' type='ordinal' />
            <column caption='Loan Id' datatype='string' name='[loan_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0689725051990021]' derivation='None' name='[none:Calculation_0689725051990021:nk]' pivot='key' type='nominal' />
            <column caption='Sanctioned Date' datatype='date' name='[sanctioned_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0528371051298816]' derivation='User' name='[usr:Calculation_0528371051298816:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sanctioned_date]' derivation='Year' name='[yr:sanctioned_date:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <slices>
            <column>[federated.0hufx7l0d94me718yhw6l1wi1kgp].[yr:sanctioned_date:ok]</column>

          <datasource-dependencies datasource='federated.0hufx7l0d94me718yhw6l1wi1kgp'>
            <column caption='Default Exposure %' datatype='real' name='[Calculation_0528371051692033]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;    IF [is_default] = 1 then [loan_amount] END&#13;&#10;)/ SUM([loan_amount])' />

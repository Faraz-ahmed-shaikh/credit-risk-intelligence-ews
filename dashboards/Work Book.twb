    <worksheet name='Defaulted Amount by Loan Tenure'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontname='Tableau Semibold' fontsize='12'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_loans_data+' name='federated.0hufx7l0d94me718yhw6l1wi1kgp' />
          </datasources>
          <datasource-dependencies datasource='federated.0hufx7l0d94me718yhw6l1wi1kgp'>
            <column caption='Loan Tenure ' datatype='string' name='[Calculation_0528371097337859]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [loan_tenure_months] &gt;= 18 then &quot;Long Term&quot;&#13;&#10;ELSEIF  [loan_tenure_months] &gt;= 12 then &quot;Mid Term&quot;&#13;&#10;ELSE &apos;Short Term&apos;&#13;&#10;END' />
            </column>
            <column caption='Defaulted Amount' datatype='integer' name='[Calculation_0680654107275266]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum(IF [is_default] = 1 THEN [loan_amount] END)' />
            </column>
            <column aggregation='Sum' caption='Is Default' datatype='integer' name='[is_default]' role='dimension' type='ordinal' />
            <column caption='Loan Amount' datatype='integer' name='[loan_amount]' role='measure' type='quantitative' />
            <column caption='Loan Tenure Months' datatype='integer' name='[loan_tenure_months]' role='measure' type='quantitative' />

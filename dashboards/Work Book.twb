            <column caption='Sanctioned Date' datatype='date' name='[sanctioned_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0680654107275266]' derivation='User' name='[usr:Calculation_0680654107275266:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sanctioned_date]' derivation='Year' name='[yr:sanctioned_date:ok]' pivot='key' type='ordinal' />
